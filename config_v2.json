{
  "UserConfig": {
    "Namespaces": [
      {
        "Name": "learning-namespace",
        "Queues": [
          {
            "Name": "orders-queue",
            "Properties": {
              "RequiresDuplicateDetection": true,
              "DuplicateDetectionHistoryTimeWindow": "PT5M"
            }
          }
        ],
        "Topics": [
          {
            "Name": "orders-topic",
            "Subscriptions": [
              { "Name": "warehouse" },
              { "Name": "email" },
              { "Name": "analytics" }
            ]
          }
        ]
      }
    ],
    "Logging": { "Type": "File" }
  }
}